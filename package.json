{
  "name": "react-native-nitro-speech-recognition",
  "version": "4.0.0",
  "description": "Speech Recognition for React Native projects using Nitro Modules",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "lib/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib/",
    "ios/",
    "android/",
    "nitrogen/generated/",
    "*.podspec",
    "react-native.config.js",
    "nitro.json"
  ],
  "scripts": {
    "nitrogen": "nitrogen",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf lib nitrogen/generated",
    "prepare": "npm run nitrogen && npm run build",
    "prepublishOnly": "npm run prepare",
    "ts:check": "tsc -p . --noEmit",
    "lint": "eslint .",
    "open:ios": "open -a \"Xcode\" example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "changeset": "changeset",
    "release": "npm run prepare && changeset publish"
  },
  "keywords": [
    "react-native",
    "speech-recognition",
    "nitro-modules",
    "SpeechRecognition",
    "webkitSpeechRecognition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamsch/expo-speech-recognition.git"
  },
  "bugs": {
    "url": "https://github.com/jamsch/expo-speech-recognition/issues"
  },
  "author": "jamsch (https://github.com/jamsch)",
  "license": "MIT",
  "homepage": "https://github.com/jamsch/expo-speech-recognition#readme",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/react": "~19.1.15",
    "globals": "17.1.0",
    "nitrogen": "^0.35.4",
    "react-native-nitro-modules": "^0.35.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.2"
  },
  "prettier": {
    "trailingComma": "all"
  }
}
